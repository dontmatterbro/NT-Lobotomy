    <!-- Nerve Generators -->
    <Item
        identifier="it_nervegenerators"
        aliases="nervegenerators"
        category="Medical"
        maxstacksize="8"
        maxstacksizecharacterinventory="8"
        scale="0.2"
        useinhealthinterface="True"
        impactsoundtag="impact_soft"
        cargocontaineridentifier="mediccrate"
        impacttolerance="5.5"
        Tags="smallitem,medical,surgery">
        <PreferredContainer
            secondary="wreckmedcab,abandonedmedcab,piratemedcab"
            spawnprobability="0.01" />

        <InventoryIcon
            texture="%ModDir%/Textures/SpriteSheet.png"
            sourcerect="384,0,128,128"
            origin="0.5,0.5" />

        <Sprite
            texture="%ModDir%/Textures/SpriteSheet.png"
            sourcerect="384,0,128,128"
            depth="0.6"
            origin="0.5,0.5" />

        <Body
            width="14"
            height="22"
            density="10" />

        <Fabricate
            suitablefabricators="medicalfabricator"
            requiredtime="18"
            amount="2">
            <RequiredSkill
                identifier="medical"
                level="65" />

            <RequiredItem
                identifier="potassium" />

            <RequiredItem
                identifier="sodium" />

            <RequiredItem
                identifier="organicfiber"
                amount="2" />

            <RequiredItem
                identifier="braintransplant"
                mincondition="0.01"
                usecondition="false" />
        </Fabricate>

        <MeleeWeapon
            slots="Any,RightHand,LeftHand"
            aimpos="5,0"
            handle1="-5,0"
            holdangle="10"
            reload="1.0">
            <StatusEffect
                type="OnBroken"
                target="This">
                <Remove />
            </StatusEffect>
        </MeleeWeapon>

        <SkillRequirementHint
            identifier="medical"
            level="50" />
    </Item>

    <!-- SFX (these ghost items get spawned in for sound effects via Lua) -->
    <!-- Orbitoclast Insertion SFX -->
    <Item
        identifier="lobosfx_orbitoclast"
        hideinmenus="true">
        <InventoryIcon
            texture="Content/Items/InventoryIconAtlas.png"
            sourcerect="0,0,1,1"
            origin="0.5,0.5" />

        <Sprite
            texture="Content/Items/Medical/Medicines.png"
            sourcerect="0,0,1,1"
            depth="0.6"
            origin="0.5,0.5" />

        <ItemComponent
            capacity="1"
            maxstacksize="1"
            hideitems="true"
            containedstateindicatorstyle="battery">
            <StatusEffect
                type="OnSpawn"
                target="This"
                disabledeltatime="true"
                stackable="false">
                <Sound
                    file="%ModDir%/Sounds/insertion1.ogg"
                    range="500" />

                <Sound
                    file="%ModDir%/Sounds/insertion2.ogg"
                    range="500" />

                <Sound
                    file="%ModDir%/Sounds/insertion3.ogg"
                    range="500" />
            </StatusEffect>
            <StatusEffect
                type="always"
                target="This"
                disabledeltatime="true"
                delay="1"
                stackable="false">
                <Remove />
            </StatusEffect>
        </ItemComponent>
    </Item>

