<?xml version="1.0" encoding="utf-8" ?>
<Items>
    <!-- Orbitoclast -->
    <Item
        identifier="it_orbitoclast"
        aliases="orbitoclast"
        category="Equipment"
        cargocontaineridentifier="mediccrate"
        Tags="smallitem,medical,surgery,surgerytool"
        useinhealthinterface="True"
        scale="0.250">
        <PreferredContainer
            primary="toxcontainer"
            spawnprobability="1" />

        <PreferredContainer
            primary="toxcontainer" />

        <Fabricate
            suitablefabricators="fabricator">
            <RequiredSkill
                identifier="medical"
                level="20" />

            <RequiredItem
                identifier="iron" />

            <RequiredItem
                identifier="zinc" />
        </Fabricate>

        <Deconstruct>
            <Item
                identifier="zinc" />
        </Deconstruct>

        <Price
            baseprice="30"
            soldbydefault="false">
            <Price
                storeidentifier="merchantmedical"
                sold="true" />
        </Price>

        <InventoryIcon
            texture="%ModDir%/Textures/SpriteSheet.png"
            sourcerect="128,0,128,128"
            origin="0.5,0.5" />

        <Sprite
            texture="%ModDir%/Textures/SpriteSheet.png"
            sourcerect="128,0,128,128"
            depth="0.55"
            origin="0.5,0.5" />

        <Body
            width="120"
            height="110"
            density="50" />

        <MeleeWeapon
            slots="Any,RightHand,LeftHand"
            aimpos="40,5"
            handle1="0,-5"
            holdangle="-90"
            reload="1.0" />

        <SkillRequirementHint
            identifier="medical"
            level="60" />
    </Item>

